VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Edge Function secrets, set with `supabase secrets set`.
RESEND_API_KEY=your-resend-key
LEADRA_FROM_EMAIL=Leadra <notifications@leadra.example>

# Final QA staging only. Never point these at production.
LEADRA_QA_ALLOW_DESTRUCTIVE=false
LEADRA_STAGING_SUPABASE_URL=https://your-staging-project.supabase.co
LEADRA_STAGING_SUPABASE_ANON_KEY=your-staging-anon-key
LEADRA_STAGING_SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
LEADRA_QA_ADMIN_EMAIL=qa-admin@leadra.example
LEADRA_QA_ADMIN_PASSWORD=replace-with-secret
LEADRA_QA_SUB_ADMIN_EMAIL=qa-sub-admin@leadra.example
LEADRA_QA_SUB_ADMIN_PASSWORD=replace-with-secret
LEADRA_QA_MANAGER_EMAIL=qa-manager-a@leadra.example
LEADRA_QA_MANAGER_PASSWORD=replace-with-secret
LEADRA_QA_SALES_EMAIL=qa-sales-a@leadra.example
LEADRA_QA_SALES_PASSWORD=replace-with-secret
LEADRA_QA_MANAGER_B_EMAIL=qa-manager-b@leadra.example
LEADRA_QA_MANAGER_B_PASSWORD=replace-with-secret
LEADRA_QA_SALES_B_EMAIL=qa-sales-b@leadra.example
LEADRA_QA_SALES_B_PASSWORD=replace-with-secret
LEADRA_QA_INACTIVE_EMAIL=qa-inactive@leadra.example
LEADRA_QA_INACTIVE_PASSWORD=replace-with-secret
