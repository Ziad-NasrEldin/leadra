# Tuist
# Keep generated Xcode project/workspace and Tuist resource accessor sources in git
# because Xcode Cloud archives ios/Leadra.xcworkspace directly from a clean
# repository checkout and does not have Tuist's local Derived/ directory.
Derived/*
!Derived/
!Derived/Sources/
!Derived/Sources/Tuist*.swift
.tuist-cache/
.tuist-state/
graph.json
Extensions/
